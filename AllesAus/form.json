{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Dokumentation & Befehle",
      "items": [
        { "type": "Label", "caption": "Verwende diese Befehle in deinen Skripten (ID = Instanz-ID dieses Moduls):" },
        { "type": "Label", "caption": "LST_Execute(ID, true/false);          // Schaltet alle Geräte mit 'Alles Aus' Haken" },
        { "type": "Label", "caption": "LST_ExecutePrimary(ID, true/false);   // Schaltet nur Geräte mit 'Primary' Haken" },
        { "type": "Label", "caption": "LST_SyncLEDs(ID);                     // Gleicht alle LEDs manuell mit dem Gerätestatus ab" }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Benachrichtigungen (Pushover)",
      "items": [
        { "type": "SelectInstance", "name": "PushoverInstance", "caption": "Pushover Instanz" },
        { "type": "ValidationTextBox", "name": "PushTitle", "caption": "Push Titel (z.B. ECO-Manager)" }
      ]
    },
    {
      "type": "List",
      "name": "DeviceList",
      "caption": "Geräte-Management & ECO-Timeout",
      "add": true,
      "delete": true,
      "sort": true,
      "columns": [
        { "caption": "Aktiv", "name": "Enabled", "width": "40px", "add": true, "edit": { "type": "CheckBox" } },
        { "caption": "Alias (Anzeige)", "name": "Alias", "width": "150px", "add": "", "edit": { "type": "ValidationTextBox" } },
        { "caption": "Status-Variable", "name": "DeviceID", "width": "200px", "add": 0, "edit": { "type": "SelectVariable" } },
        { "caption": "Typ", "name": "DeviceType", "width": "140px", "add": "parent", "edit": { "type": "Select", "options": [
              { "caption": "HomeMatic Schalter", "value": "parent" },
              { "caption": "HomeMatic Dimmer", "value": "dimmer" },
              { "caption": "WLED / RGB (Standard)", "value": "request" },
              { "caption": "Script (Chromo)", "value": "chromo" }
            ]
        }},
        { "caption": "Alles Aus", "name": "UseAllesAus", "width": "75px", "add": true, "edit": { "type": "CheckBox" } },
        { "caption": "ECO (Min)", "name": "EcoMinutes", "width": "70px", "add": 0, "edit": { "type": "NumberSpinner", "minimum": 0 } },
        { "caption": "Primary", "name": "IsPrimary", "width": "70px", "add": false, "edit": { "type": "CheckBox" } },
        { "caption": "LED 1", "name": "LedVarID1", "width": "120px", "add": 0, "edit": { "type": "SelectVariable" } },
        { "caption": "LED 2", "name": "LedVarID2", "width": "120px", "add": 0, "edit": { "type": "SelectVariable" } }
      ]
    }
  ],
  "actions": [
    { "type": "Button", "label": "Zentrale: Alles AUS", "onClick": "LST_Execute($id, false);" },
    { "type": "Button", "label": "Alle LEDs synchronisieren", "onClick": "LST_SyncLEDs($id);" }
  ]
}
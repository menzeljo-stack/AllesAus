{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Benachrichtigungen (Pushover)",
      "items": [
        { "type": "SelectInstance", "name": "PushoverInstance", "caption": "Pushover Instanz" },
        { "type": "ValidationTextBox", "name": "PushTitle", "caption": "Push Titel (z.B. ECO-Manager)" }
      ]
    },
    {
      "type": "List",
      "name": "DeviceList",
      "caption": "Geräte-Management & ECO-Timeout",
      "add": true,
      "delete": true,
      "sort": true,
      "columns": [
        { "caption": "Aktiv", "name": "Enabled", "width": "40px", "add": true, "edit": { "type": "CheckBox" } },
        { "caption": "Status-Variable", "name": "DeviceID", "width": "200px", "add": 0, "edit": { "type": "SelectVariable" } },
        { "caption": "Typ", "name": "DeviceType", "width": "120px", "add": "parent", "edit": { "type": "Select", "options": [
              { "caption": "HM Schalter", "value": "parent" },
              { "caption": "HM Dimmer", "value": "dimmer" },
              { "caption": "Standard / Shelly", "value": "request" },
              { "caption": "Script (Chromo)", "value": "chromo" }
            ]
        }},
        { "caption": "Alles Aus", "name": "UseAllesAus", "width": "70px", "add": true, "edit": { "type": "CheckBox" } },
        { "caption": "ECO (Min)", "name": "EcoMinutes", "width": "80px", "add": 0, "edit": { "type": "NumberSpinner", "minimum": 0 } },
        { "caption": "LED 1", "name": "LedVarID1", "width": "100px", "add": 0, "edit": { "type": "SelectVariable" } },
        { "caption": "LED 2", "name": "LedVarID2", "width": "100px", "add": 0, "edit": { "type": "SelectVariable" } }
      ]
    }
  ],
  "actions": [
    { "type": "Button", "label": "Alles AUS auslösen", "onClick": "ALOA_Execute($id, false);" },
    { "type": "Button", "label": "Alle LEDs synchronisieren", "onClick": "ALOA_SyncLEDs($id);" }
  ]
}